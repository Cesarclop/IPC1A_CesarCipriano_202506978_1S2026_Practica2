package gui;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.io.File;
import java.io.FileWriter;
import java.io.IOException;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import reportes.Ejecucion;

public class PanelReportes extends JPanel {

    private VentanaPrincipal ventana;
    private JTable tablaHistorial;
    private DefaultTableModel modeloTabla;
    private int totalEjecuciones = 0;

    public PanelReportes(VentanaPrincipal ventana) {
        this.ventana = ventana;
        setLayout(new BorderLayout(10, 10));
        setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        construirInterfaz();
    }

    private void construirInterfaz() {
        JLabel titulo = new JLabel("Historial de Ejecuciones", SwingConstants.CENTER);
        titulo.setFont(new Font("Segoe UI", Font.BOLD, 18));
        add(titulo, BorderLayout.NORTH);

        String[] columnas = {"No.", "Algoritmo", "Orden", "n","Comparaciones", "Intercambios", "Iteraciones", "Tiempo (ms)"};
        modeloTabla = new DefaultTableModel(columnas, 0);
        tablaHistorial = new JTable(modeloTabla);
        tablaHistorial.setFillsViewportHeight(true);
        add(new JScrollPane(tablaHistorial), BorderLayout.CENTER);

        JPanel panelInferior = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        JButton btnRegresar = new JButton("Regresar al Menú");
        btnRegresar.addActionListener(e -> ventana.mostrarPanel("menu"));
        panelInferior.add(btnRegresar);
        add(panelInferior, BorderLayout.SOUTH);
    }

    public int getSiguienteNumero() {
        return totalEjecuciones + 1;
    }

    public void agregarEjecucion(Ejecucion ejecucion) {
        totalEjecuciones++;

        Object[] fila = {ejecucion.getNumero(),ejecucion.getAlgoritmo(),ejecucion.getOrden(),ejecucion.getTamanio(),ejecucion.getComparaciones(),ejecucion.getIntercambios(),ejecucion.getIteraciones(),ejecucion.getTiempoMs()};
        modeloTabla.addRow(fila);
        generarArchivoHTML(ejecucion);
    }

    private void generarArchivoHTML(Ejecucion e) {
        File carpetaReportes = new File("reportes");
        if (!carpetaReportes.exists()) {
            carpetaReportes.mkdir();
        }

        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss"));
        String nombreArchivo = "reporte_" + timestamp + ".html";
        File archivoHTML = new File(carpetaReportes, nombreArchivo);

        try (FileWriter escritor = new FileWriter(archivoHTML)) {
            escritor.write("<!DOCTYPE html>\n");
            escritor.write("<html>\n");
            escritor.write("<head><meta charset='UTF-8'><title>Reporte de Ordenamiento</title></head>\n");
            escritor.write("<body>\n");
            escritor.write("<h1>Reporte de Ejecución #" + e.getNumero() + "</h1>\n");
            escritor.write("<p>Fecha: " + LocalDateTime.now().format(DateTimeFormatter.ofPattern("dd/MM/yyyy")) + "</p>\n");
            escritor.write("<h2>Resumen</h2>\n");
            escritor.write("<table border='1'>\n");
            escritor.write("<tr><th>Algoritmo</th><td>" + e.getAlgoritmo() + "</td></tr>\n");
            escritor.write("<tr><th>Orden</th><td>" + e.getOrden() + "</td></tr>\n");
            escritor.write("<tr><th>Tamaño (n)</th><td>" + e.getTamanio() + "</td></tr>\n");
            escritor.write("<tr><th>Comparaciones</th><td>" + e.getComparaciones() + "</td></tr>\n");
            escritor.write("<tr><th>Intercambios</th><td>" + e.getIntercambios() + "</td></tr>\n");
            escritor.write("<tr><th>Iteraciones</th><td>" + e.getIteraciones() + "</td></tr>\n");
            escritor.write("<tr><th>Tiempo (ms)</th><td>" + e.getTiempoMs() + "</td></tr>\n");
            escritor.write("<tr><th>Velocidad</th><td>" + e.getVelocidad() + "</td></tr>\n");
            escritor.write("</table>\n");
            escritor.write("<h2>Arreglo Original</h2>\n");
            escritor.write("<p>" + e.getArregloOriginal() + "</p>\n");
            escritor.write("<h2>Arreglo Ordenado</h2>\n");
            escritor.write("<p>" + e.getArregloFinal() + "</p>\n");
            escritor.write("<h2>Perfil del Sistema</h2>\n");
            escritor.write("<pre>" + e.getPerfilSistema() + "</pre>\n");
            escritor.write("</body></html>\n");
        } catch (IOException ex) {
            System.err.println("Error al generar reporte HTML: " + ex.getMessage());
        }
    }
}
